    {
      "src": "fav/android-chrome-192x192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "fav/android-chrome-512x512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/task-list-en.png",
      "type": "image/png",
      "sizes": "1365x1227",
      "label": "Task Tracer task list"
    },
    {
      "src": "screenshots/add-task-en.png",
      "type": "image/png",
      "sizes": "1365x1227",
      "label": "Task Tracer add task dialog"
    }
  ],
  "shortcuts": [
    {
      "name": "Quick Capture",
